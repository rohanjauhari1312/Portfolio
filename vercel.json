    { "source": "/trywatchlessai", "destination": "https://web-production-6798a.up.railway.app/", "permanent": false },
    { "source": "/trywatchlessai/:path*", "destination": "https://web-production-6798a.up.railway.app/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/watchlessai", "destination": "/index.html" },
    { "source": "/swifthire", "destination": "/index.html" },
