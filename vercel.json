    { "source": "/experience", "destination": "/index.html" },
    { "source": "/projects", "destination": "/index.html" },
    { "source": "/achievements", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/resume", "destination": "/resume.pdf" }
  ]
